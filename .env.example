# Copy to .env and fill in. .env is git-ignored — never commit real tokens.
# Taskfile loads these automatically (dotenv) for `task publish-ovsx` / `task publish`.

# Open VSX access token — https://open-vsx.org/user-settings/tokens
OVSX_PAT=

# VS Code Marketplace PAT — https://dev.azure.com (scope: Marketplace > Manage)
VSCE_PAT=
